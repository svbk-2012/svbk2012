<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Back2Work</title>
<style>
:root {
  --bg-color: #f0f4f8;
  --text-color: #333;
  --card-bg: #f8fafc;
  --border-color: #ccc;
  --primary-color: #3b82f6;
  --primary-hover: #2563eb;
  --success-color: #10b981;
  --success-hover: #059669;
  --danger-color: #ef4444;
  --danger-hover: #b91c1c;
  --warning-color: #f59e0b;
  --secondary-color: #6b7280;
  --secondary-hover: #4b5563;
}

body.dark-mode {
  --bg-color: #1a202c;
  --text-color: #e2e8f0;
  --card-bg: #2d3748;
  --border-color: #4a5568;
  --primary-color: #4299e1;
  --primary-hover: #3182ce;
  --success-color: #48bb78;
  --success-hover: #38a169;
  --danger-color: #f56565;
  --danger-hover: #e53e3e;
  --warning-color: #ed8936;
  --secondary-color: #718096;
  --secondary-hover: #4a5568;
}

body { font-family: Arial, sans-serif; max-width: 800px; margin: 20px auto; padding: 20px; background: var(--bg-color); color: var(--text-color); transition: background-color 0.3s, color 0.3s; }

.header-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
h1 { color: #1e3a8a; margin: 0; }
.settings-btn { background: var(--secondary-color); color: white; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; }
.settings-btn:hover { background: var(--secondary-hover); }

.modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); }
.modal-content { background-color: var(--card-bg); margin: 5% auto; padding: 20px; border-radius: 8px; width: 90%; max-width: 500px; position: relative; }
.close { color: var(--text-color); float: right; font-size: 28px; font-weight: bold; cursor: pointer; }
.close:hover { color: var(--danger-color); }

.setting-item { margin: 15px 0; }
.setting-item label { display: block; margin-bottom: 5px; font-weight: bold; }
.toggle-switch { position: relative; display: inline-block; width: 60px; height: 34px; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px; }
.slider:before { position: absolute; content: ""; height: 26px; width: 26px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
input:checked + .slider { background-color: var(--primary-color); }
input:checked + .slider:before { transform: translateX(26px); }

.charts-container { margin: 20px 0; }
.charts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin: 20px 0; }
.chart-card { background: var(--card-bg); padding: 15px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); text-align: center; }
.chart-title { font-weight: bold; margin-bottom: 10px; }
.pie-chart { width: 120px; height: 120px; margin: 0 auto; }
.chart-legend { margin-top: 10px; font-size: 0.9em; }
.legend-item { display: inline-block; margin: 2px 5px; }
.legend-color { display: inline-block; width: 12px; height: 12px; margin-right: 4px; border-radius: 2px; }

label { display: block; margin: 12px 0 6px; font-weight: bold; }
input, select { width: 100%; padding: 10px; margin-bottom: 12px; border: 1px solid var(--border-color); border-radius: 6px; font-size: 1em; background: var(--card-bg); color: var(--text-color); }
button { padding: 10px 18px; background: var(--primary-color); color: white; border: none; border-radius: 6px; cursor: pointer; margin: 8px 0; }
button:hover { background: var(--primary-hover); }
.task-list { list-style: none; padding: 0; }
.task { background: var(--card-bg); padding: 16px; margin: 12px 0; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; }
.task.overdue { border-left: 6px solid var(--danger-color); background: #fee2e2; }
.task.today { border-left: 6px solid var(--warning-color); background: #fef3c7; }
.task.soon { border-left: 6px solid #eab308; background: #fefce8; }
.urgency-label { font-weight: bold; color: #1e40af; margin-left: 4px; }
.complete-btn { background: var(--success-color); border: none; border-radius: 6px; cursor: pointer; padding: 6px 12px; color: white; margin-left: 4px; }
.complete-btn:hover { background: var(--success-hover); }
.edit-btn { background: var(--warning-color); border: none; border-radius: 6px; cursor: pointer; padding: 6px 12px; color: white; margin-left: 4px; }
.edit-btn:hover { background: #d97706; }
.delete-btn { background: var(--danger-color); border: none; border-radius: 6px; cursor: pointer; padding: 6px 12px; color: white; margin-left: 4px; }
.delete-btn:hover { background: var(--danger-hover); }
.clear-btn { background: var(--secondary-color); margin: 20px auto; display: block; color: white; padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; }
.clear-btn:hover { background: var(--secondary-hover); }
#stats { text-align: center; font-size: 1.1em; font-weight: bold; margin: 20px 0; color: #1e40af; }
.error { color: var(--danger-color); font-size: 0.9em; margin-top: -10px; margin-bottom: 10px; }

.subject-input-group { display: flex; gap: 10px; align-items: center; }
.subject-input-group input { flex: 1; margin-bottom: 0; }
.add-subject-btn { padding: 10px; background: var(--success-color); margin: 0; }
.add-subject-btn:hover { background: var(--success-hover); }
.subject-list { margin-top: 10px; }
.subject-item { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; }
.remove-subject-btn { background: var(--danger-color); padding: 4px 8px; font-size: 0.8em; margin: 0; }
.remove-subject-btn:hover { background: var(--danger-hover); }
</style>
</head>
<body>

<div class="header-container">
  <h1>Back2Work</h1>
  <button class="settings-btn" onclick="openSettings()">⚙️</button>
</div>

<!-- Settings Modal -->
<div id="settingsModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeSettings()">&times;</span>
    <h2>Settings</h2>
   
    <div class="setting-item">
      <label for="userName">User Name:</label>
      <input type="text" id="userName" placeholder="Enter your name">
    </div>
   
    <div class="setting-item">
      <label for="darkMode">Dark Mode:</label>
      <label class="toggle-switch">
        <input type="checkbox" id="darkMode" onchange="toggleDarkMode()">
        <span class="slider"></span>
      </label>
    </div>
   
    <div class="setting-item">
      <label for="showCharts">Show Subject Charts:</label>
      <label class="toggle-switch">
        <input type="checkbox" id="showCharts" onchange="toggleCharts()">
        <span class="slider"></span>
      </label>
    </div>
   
    <div class="setting-item">
      <label>Manage Subjects:</label>
      <div class="subject-input-group">
        <input type="text" id="newSubject" placeholder="Add new subject">
        <button class="add-subject-btn" onclick="addSubject()">Add</button>
      </div>
      <div id="subjectList" class="subject-list"></div>
    </div>
   
    <div class="setting-item">
      <button onclick="resetAll()" style="background: var(--danger-color);">Reset Everything</button>
    </div>
  </div>
</div>

<!-- Charts Section -->
<div id="chartsSection" class="charts-container" style="display: none;">
  <h2>Subject Progress Charts</h2>
  <div id="chartsKey" class="chart-legend" style="text-align: center; margin-bottom: 20px;">
    <span class="legend-item"><span class="legend-color" style="background: #10b981;"></span>Early</span>
    <span class="legend-item"><span class="legend-color" style="background: #3b82f6;"></span>On Time</span>
    <span class="legend-item"><span class="legend-color" style="background: #ef4444;"></span>Late</span>
  </div>
  <div id="chartsGrid" class="charts-grid"></div>
</div>

<div id="hw-form">
  <h2>Add Assignment</h2>
  <label>Assignment name</label>
  <input type="text" id="taskName" placeholder="e.g. Math worksheet" required />
  <label>Due date (MM/DD/YYYY)</label>
  <input type="text" id="dueDate" placeholder="m/dd/yyyy" required />
  <div id="dateError" class="error" style="display: none;">Invalid date format. Please use MM/DD/YYYY format.</div>
  <label>Difficulty (1=easy – 5=hard)</label>
  <select id="difficulty">
    <option value="1">1 - Easy</option>
    <option value="2">2</option>
    <option value="3">3</option>
    <option value="4">4</option>
    <option value="5">5 - Hard</option>
  </select>
  <label>Subject</label>
  <select id="subject" required></select>
  <button onclick="addTask()">Add Assignment</button>
</div>

<div id="stats">Active: 0 | Completed: 0 | Progress: 100%</div>

<h2>Active Assignments</h2>
<ul id="task-list" class="task-list"></ul>

<h2>Completed Assignments</h2>
<ul id="completed-list" class="task-list"></ul>

<button class="clear-btn" onclick="clearAll()">Clear All</button>
<button class="clear-btn" onclick="exportHomework()">Download Homework</button>
<input type="file" id="importFile" style="display:none;" accept=".json" onchange="importHomework(event)">
<button class="clear-btn" onclick="document.getElementById('importFile').click()">Load Homework</button>

<script>
let tasks = [];
let completed = [];
let userName = localStorage.getItem('myHwUser') || '';
let showCharts = localStorage.getItem('showCharts') === 'true';
let darkMode = localStorage.getItem('darkMode') === 'true';
let subjects = JSON.parse(localStorage.getItem('subjects')) || ['Math', 'Science', 'English', 'History', 'Art'];
let editingIndex = -1;

function askUserName() {
  if (!userName) {
    let name = prompt("What's your name? (used for saving/loading your homework)");
    if(name) name = name.trim();
    if(!name) name = "unknown";
    userName = name;
    localStorage.setItem('myHwUser', userName);
  }
}

// ---------------- Settings functions ----------------
function openSettings() {
  document.getElementById('settingsModal').style.display = 'block';
  document.getElementById('userName').value = userName;
  document.getElementById('darkMode').checked = darkMode;
  document.getElementById('showCharts').checked = showCharts;
  renderSubjectList();
}

function closeSettings() {
  document.getElementById('settingsModal').style.display = 'none';
}

function toggleDarkMode() {
  darkMode = document.getElementById('darkMode').checked;
  localStorage.setItem('darkMode', darkMode);
  document.body.classList.toggle('dark-mode', darkMode);
}

function toggleCharts() {
  showCharts = document.getElementById('showCharts').checked;
  localStorage.setItem('showCharts', showCharts);
  document.getElementById('chartsSection').style.display = showCharts ? 'block' : 'none';
  if (showCharts) {
    renderCharts();
  }
}

function addSubject() {
  const newSubject = document.getElementById('newSubject').value.trim();
  if (newSubject && !subjects.includes(newSubject)) {
    subjects.push(newSubject);
    localStorage.setItem('subjects', JSON.stringify(subjects));
    document.getElementById('newSubject').value = '';
    renderSubjectList();
    populateSubjectDropdown();
  }
}

function removeSubject(index) {
  subjects.splice(index, 1);
  localStorage.setItem('subjects', JSON.stringify(subjects));
  renderSubjectList();
  populateSubjectDropdown();
}

function renderSubjectList() {
  const list = document.getElementById('subjectList');
  list.innerHTML = '';
  subjects.forEach((subject, index) => {
    const item = document.createElement('div');
    item.className = 'subject-item';
    item.innerHTML = `
      <span>${subject}</span>
      <button class="remove-subject-btn" onclick="removeSubject(${index})">Remove</button>
    `;
    list.appendChild(item);
  });
}

function resetAll() {
  if (confirm('This will clear ALL data including assignments, settings, and cache. Are you sure?')) {
    localStorage.clear();
    tasks = [];
    completed = [];
    userName = '';
    showCharts = false;
    darkMode = false;
    subjects = ['Math', 'Science', 'English', 'History', 'Art'];
    editingIndex = -1;
    document.body.classList.remove('dark-mode');
    document.getElementById('chartsSection').style.display = 'none';
    closeSettings();
    renderAll();
    populateSubjectDropdown();
  }
}

// ---------------- Chart functions ----------------
function renderCharts() {
  const grid = document.getElementById('chartsGrid');
  grid.innerHTML = '';
 
  const subjectStats = {};
  subjects.forEach(subject => {
    subjectStats[subject] = { early: 0, ontime: 0, late: 0 };
  });
 
  completed.forEach(task => {
    if (subjectStats[task.subject]) {
      const completedDate = new Date(task.completedOn);
      const dueDate = new Date(task.due.year, task.due.month - 1, task.due.day);
      const daysDiff = Math.floor((dueDate - completedDate) / 86400000);
     
      if (daysDiff > 0) {
        subjectStats[task.subject].early++;
      } else if (daysDiff === 0) {
        subjectStats[task.subject].ontime++;
      } else {
        subjectStats[task.subject].late++;
      }
    }
  });
 
  subjects.forEach(subject => {
    const stats = subjectStats[subject];
    const total = stats.early + stats.ontime + stats.late;
   
    // Always show chart, even if no completed assignments
    const chartCard = document.createElement('div');
    chartCard.className = 'chart-card';
   
    const svg = createPieChart(stats.early, stats.ontime, stats.late);
   
    chartCard.innerHTML = `
      <div class="chart-title">${subject}</div>
      <div class="pie-chart">${svg || '<svg width="120" height="120" viewBox="0 0 120 120"><circle cx="60" cy="60" r="50" fill="#e5e7eb" stroke="white" stroke-width="2"/></svg>'}</div>
      <div class="chart-legend">
        <div>Early: ${stats.early}</div>
        <div>On Time: ${stats.ontime}</div>
        <div>Late: ${stats.late}</div>
      </div>
    `;
   
    grid.appendChild(chartCard);
  });
}

function createPieChart(early, ontime, late) {
  const total = early + ontime + late;
  if (total === 0) return '';
 
  let svg = `<svg width="120" height="120" viewBox="0 0 120 120">`;
 
  // If only one type, fill the entire circle
  if (early > 0 && ontime === 0 && late === 0) {
    svg += `<circle cx="60" cy="60" r="50" fill="#10b981" stroke="white" stroke-width="2"/>`;
  } else if (ontime > 0 && early === 0 && late === 0) {
    svg += `<circle cx="60" cy="60" r="50" fill="#3b82f6" stroke="white" stroke-width="2"/>`;
  } else if (late > 0 && early === 0 && ontime === 0) {
    svg += `<circle cx="60" cy="60" r="50" fill="#ef4444" stroke="white" stroke-width="2"/>`;
  } else {
    // Multiple types - create pie slices
    const earlyAngle = (early / total) * 360;
    const ontimeAngle = (ontime / total) * 360;
    const lateAngle = (late / total) * 360;
   
    let currentAngle = 0;
   
    if (early > 0) {
      const path = createPieSlice(60, 60, 50, currentAngle, currentAngle + earlyAngle, '#10b981');
      svg += path;
      currentAngle += earlyAngle;
    }
   
    if (ontime > 0) {
      const path = createPieSlice(60, 60, 50, currentAngle, currentAngle + ontimeAngle, '#3b82f6');
      svg += path;
      currentAngle += ontimeAngle;
    }
   
    if (late > 0) {
      const path = createPieSlice(60, 60, 50, currentAngle, currentAngle + lateAngle, '#ef4444');
      svg += path;
    }
  }
 
  svg += '</svg>';
  return svg;
}

function createPieSlice(cx, cy, radius, startAngle, endAngle, color) {
  const startAngleRad = (startAngle - 90) * Math.PI / 180;
  const endAngleRad = (endAngle - 90) * Math.PI / 180;
 
  const x1 = cx + radius * Math.cos(startAngleRad);
  const y1 = cy + radius * Math.sin(startAngleRad);
  const x2 = cx + radius * Math.cos(endAngleRad);
  const y2 = cy + radius * Math.sin(endAngleRad);
 
  const largeArc = endAngle - startAngle > 180 ? 1 : 0;
 
  const path = `M ${cx} ${cy} L ${x1} ${y1} A ${radius} ${radius} 0 ${largeArc} 1 ${x2} ${y2} Z`;
 
  return `<path d="${path}" fill="${color}" stroke="white" stroke-width="2"/>`;
}

// ---------------- Task functions ----------------
try { tasks = JSON.parse(localStorage.getItem('myHwTasks')) || []; } catch(e){ tasks=[]; }
try { completed = JSON.parse(localStorage.getItem('myHwCompleted')) || []; } catch(e){ completed=[]; }

function saveData() {
  localStorage.setItem('myHwTasks', JSON.stringify(tasks));
  localStorage.setItem('myHwCompleted', JSON.stringify(completed));
  renderAll();
}

function populateSubjectDropdown() {
  const select = document.getElementById('subject');
  select.innerHTML = '';
  subjects.forEach(subject => {
    const option = document.createElement('option');
    option.value = subject;
    option.textContent = subject;
    select.appendChild(option);
  });
}

function parseDate(str) {
  const p = str.split('/');
  if(p.length !== 3) return null;
  const month = parseInt(p[0]);
  const day = parseInt(p[1]);
  const year = parseInt(p[2]);
 
  if (month < 1 || month > 12 || day < 1 || day > 31 || year < 1900 || year > 2100) {
    return null;
  }
 
  const date = new Date(year, month - 1, day);
  if (date.getMonth() !== month - 1 || date.getDate() !== day || date.getFullYear() !== year) {
    return null;
  }
 
  return { year, month, day };
}

function daysUntil(due) {
  const d = new Date(due.year, due.month-1, due.day);
  const t = new Date(); t.setHours(0,0,0,0);
  return Math.floor((d - t)/86400000);
}

function getUrgency(due){
  const days = daysUntil(due);
  if(days<0) return {cls:'overdue', lbl:'Overdue!'};
  if(days===0) return {cls:'today', lbl:'Today – Do Now!'};
  if(days===1) return {cls:'soon', lbl:'Tomorrow'};
  if(days<=3) return {cls:'soon', lbl:`In ${days} days`};
  return {cls:'', lbl:`In ${days} days`};
}

function addTask(){
  const name = document.getElementById('taskName').value.trim();
  const due = document.getElementById('dueDate').value.trim();
  const difficulty = parseInt(document.getElementById('difficulty').value);
  const subject = document.getElementById('subject').value;
 
  document.getElementById('dateError').style.display = 'none';
 
  if(!name || !due || !subject){
    alert('Name, due date, and subject are required');
    return;
  }
 
  const dueParsed = parseDate(due);
  if(!dueParsed){
    document.getElementById('dateError').style.display = 'block';
    return;
  }
 
  if (editingIndex >= 0) {
    tasks[editingIndex] = {name, dueStr:due, due:dueParsed, difficulty, subject};
    editingIndex = -1;
  } else {
    tasks.push({name, dueStr:due, due:dueParsed, difficulty, subject});
  }
 
  tasks.sort((a,b)=>{
    const da=daysUntil(a.due), db=daysUntil(b.due);
    if(da!==db) return da-db;
    return b.difficulty - a.difficulty;
  });
 
  ['taskName','dueDate'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('difficulty').value = '1';
  saveData();
}

function editTask(i){
  const t = tasks[i];
  document.getElementById('taskName').value = t.name;
  document.getElementById('dueDate').value = t.dueStr;
  document.getElementById('difficulty').value = t.difficulty;
  document.getElementById('subject').value = t.subject;
  editingIndex = i;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function completeTask(i){
  const t = tasks.splice(i,1)[0];
  t.completedOn = new Date().toLocaleDateString();
  completed.push(t);
  saveData();
}

function deleteTask(i,completedSection=false){
  if(completedSection) completed.splice(i,1);
  else tasks.splice(i,1);
  saveData();
}

function clearAll(){
  if(confirm('Clear everything?')){
    tasks=[]; completed=[];
    saveData();
  }
}

// ---------------- Export / Import ----------------
function exportHomework(){
  askUserName();
  const data = {tasks, completed, subjects};
  const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `myHomework-${userName}.json`;
  a.click();
  URL.revokeObjectURL(url);
}

function importHomework(event){
  askUserName();
  const file = event.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try{
      const data = JSON.parse(e.target.result);
      if(data.tasks && data.completed){
        tasks = data.tasks;
        completed = data.completed;
        if(data.subjects) {
          subjects = data.subjects;
          localStorage.setItem('subjects', JSON.stringify(subjects));
          populateSubjectDropdown();
        }
        saveData();
        alert('Homework loaded successfully!');
      } else {
        alert('Invalid file.');
      }
    } catch(err){ alert('Error reading file'); }
  };
  reader.readAsText(file);
}

// ---------------- Render functions ----------------
function renderTasks(){
  const tl = document.getElementById('task-list'); tl.innerHTML='';
  tasks.forEach((t,i)=>{
    const u = getUrgency(t.due);
    const li = document.createElement('li'); li.className=`task ${u.cls}`;
    li.innerHTML=`
      <div><strong>${t.name}</strong><br>Due: ${t.dueStr} ${u.lbl}<br>Difficulty: ${t.difficulty} • Subject: ${t.subject}</div>
      <div>
        <button class="complete-btn" onclick="completeTask(${i})">Done</button>
        <button class="edit-btn" onclick="editTask(${i})">Edit</button>
      </div>
    `;
    tl.appendChild(li);
  });

  const cl = document.getElementById('completed-list'); cl.innerHTML='';
  completed.forEach((t,i)=>{
    const li = document.createElement('li'); li.className='task';
    li.innerHTML=`
      <div><strong>${t.name}</strong> Due: ${t.dueStr} ${t.completedOn ? 'Completed: ' + t.completedOn : ''}</div>
      <div><button class="delete-btn" onclick="deleteTask(${i}, true)">Delete</button></div>
    `;
    cl.appendChild(li);
  });
}

function renderStats(){
  const a = tasks.length, c = completed.length;
  const p = (a+c===0)?100:Math.round((c/(a+c))*100);
  document.getElementById('stats').textContent=`Active: ${a} | Completed: ${c} | Progress: ${p}%`;
}

function renderAll(){
  renderTasks();
  renderStats();
  if (showCharts) {
    setTimeout(() => renderCharts(), 100);
  }
}

// Initialize
document.addEventListener('DOMContentLoaded', function() {
  if (darkMode) {
    document.body.classList.add('dark-mode');
  }
  if (showCharts) {
    document.getElementById('chartsSection').style.display = 'block';
    setTimeout(() => renderCharts(), 100);
  }
  populateSubjectDropdown();
  renderAll();
});

// Close modal when clicking outside
window.onclick = function(event) {
  const modal = document.getElementById('settingsModal');
  if (event.target === modal) {
    closeSettings();
  }
}
</script>
</body>
</html>

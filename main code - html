<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Game Library Hub</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #111;
      color: #f5f5f5;
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    header {
      padding: 10px 20px;
      background: #222;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    header h1 {
      font-size: 20px;
      margin: 0;
    }

    #game-select {
      padding: 5px 10px;
      font-size: 14px;
    }

    main {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    #game-info {
      padding: 10px 20px;
      background: #181818;
      font-size: 14px;
      border-top: 1px solid #333;
      border-bottom: 1px solid #333;
    }

    #game-frame {
      flex: 1;
      border: none;
      width: 100%;
      background: #000;
    }

    footer {
      padding: 8px 20px;
      background: #222;
      font-size: 12px;
      text-align: center;
      color: #aaa;
    }

    a {
      color: #4fa3ff;
    }
  </style>
</head>
<body>
  <header>
    <h1>Game Library Hub</h1>
    <select id="game-select">
      <option value="">Select a game...</option>
      <!-- Replace these URLs with real CrazyGames game URLs -->
      <option value="https://www.crazygames.com/game/drive-mad">Drive Mad</option>
      <option value="https://www.crazygames.com/game/shell-shockers">Shell Shockers</option>
      <option value="https://www.crazygames.com/game/rocket-soccer-derby">Rocket Soccer Derby</option>
      <option value="https://www.crazygames.com/game/basket-random">Basket Random</option>
      <option value="https://www.crazygames.com/game/ovo">OvO</option>
    </select>
  </header>

  <main>
    <div id="game-info">
      <strong>Instructions:</strong> Choose a game from the dropdown above.  
      Games are loaded from <a href="https://www.crazygames.com" target="_blank">CrazyGames.com</a> in the frame below.
    </div>
    <iframe id="game-frame" src=""></iframe>
  </main>

  <footer>
    Game library demo – games hosted by CrazyGames.com
  </footer>

  <script>
    const select = document.getElementById('game-select');
    const frame = document.getElementById('game-frame');

    select.addEventListener('change', () => {
      const url = select.value;
      if (url) {
        frame.src = url;
      } else {
        frame.src = '';
      }
    });
  </script>
</body>
</html>
